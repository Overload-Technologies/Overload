#include ":Shaders/Common/Buffers/SkinningSSBO.ovfxh"

mat4 ComputeSkinningMatrix(uvec4 p_boneIDs, vec4 p_boneWeights)
{
    mat4 skinMat = mat4(0.0);

    skinMat += p_boneWeights.x * ssbo_Bones[p_boneIDs.x];
    skinMat += p_boneWeights.y * ssbo_Bones[p_boneIDs.y];
    skinMat += p_boneWeights.z * ssbo_Bones[p_boneIDs.z];
    skinMat += p_boneWeights.w * ssbo_Bones[p_boneIDs.w];

    return skinMat;
}

